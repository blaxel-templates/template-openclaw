# Model configuration
OPENCLAW_MODEL=anthropic/claude-opus-4-6
ANTHROPIC_API_KEY=your-anthropic-api-key
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# Basic auth credentials (self-hosted only, not needed on Blaxel)
# If not set, a setup wizard will run on first visit
# PROXY_USER=admin
# PROXY_PASSWORD=your-password

# Blaxel sandbox (optional)
# BL_WORKSPACE=my-workspace
# BL_API_KEY=bl_...
