# Model configuration
# Uncomment API key env var as needed depending on OPENCLAW_MODEL
# Also update blaxel.toml for correct env var selection
OPENCLAW_MODEL=anthropic/claude-opus-4-6
ANTHROPIC_API_KEY=your-anthropic-api-key
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# Proxy authentication (optional)
# If not set, a setup wizard will run on first visit
# PROXY_USER=admin
# PROXY_PASSWORD=your-password

# Blaxel sandbox (optional)
# If not set and BL_CLOUD is not present, the setup wizard will ask for these
# BL_WORKSPACE=my-workspace
# BL_API_KEY=bl_...